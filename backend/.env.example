# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
TRUST_PROXY=false

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tickets_db?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera secrets seguros con: openssl rand -base64 48
JWT_ACCESS_SECRET=your_super_secret_access_key_minimum_32_characters_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_characters_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5180

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_ENABLED=true

# ─── Login hardening (anti brute-force) ─────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
